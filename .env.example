# Database
DATABASE_URL="postgresql://user:password@localhost:5432/heretix"

# API Server
PORT=5000

# API Key authentication (required — requests without a matching x-api-key header are rejected with 401)
API_KEY=your-api-key-here

# NVD (National Vulnerability Database) API Key
# Get your key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Cisco API credentials (for Cisco advisory import)
CISCO_CLIENT_ID=
CISCO_CLIENT_SECRET=
