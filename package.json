{
  "name": "heretix-api",
  "version": "0.1.0",
  "type": "module",
  "description": "Vulnerability Management API - Simple PostgreSQL-only backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:erd": "prisma generate && echo \"ER diagram generated at docs/erd.md\"",
    "import:osv": "node dist/scripts/import-osv.js",
    "import:nvd": "node dist/scripts/import-nvd.js",
    "import:kev": "node dist/scripts/import-kev.js",
    "import:epss": "node dist/scripts/import-epss.js",
    "import:fortinet": "node dist/scripts/import-fortinet.js",
    "import:pan": "node dist/scripts/import-pan.js",
    "import:cisco": "node dist/scripts/import-cisco.js",
    "import:oracle-linux": "node dist/scripts/import-oracle-linux.js",
    "import:sophos": "node dist/scripts/import-sophos.js",
    "import:sonicwall": "node dist/scripts/import-sonicwall.js",
    "import:oracle-cpu": "node dist/scripts/import-oracle-cpu.js",
    "import:broadcom": "node dist/scripts/import-broadcom.js",
    "validate:nginx": "node dist/scripts/validate-nginx.js",
    "validate:tomcat": "node dist/scripts/validate-tomcat.js",
    "validate:apache": "node dist/scripts/validate-apache.js"
  },
  "keywords": [
    "vulnerability",
    "osv",
    "security",
    "api"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.15.0",
    "bzip2": "^0.1.1",
    "dotenv": "^17.2.3",
    "fast-xml-parser": "^5.7.1",
    "fastify": "^5.8.5",
    "node-cron": "^4.2.1",
    "pg": "^8.17.0",
    "pino": "^10.1.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "prisma": "^7.7.0",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "zod": "^4.3.5"
  },
  "pnpm": {
    "overrides": {
      "defu": ">=6.1.5",
      "basic-ftp": ">=5.2.2",
      "lodash": ">=4.18.0",
      "lodash-es": ">=4.18.0",
      "ajv": ">=8.18.0",
      "follow-redirects": ">=1.16.0",
      "picomatch": ">=4.0.4",
      "dompurify": ">=3.4.0",
      "hono": ">=4.12.14",
      "@hono/node-server": ">=1.19.13",
      "uuid": ">=14.0.0",
      "postcss": ">=8.5.10"
    },
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma",
      "puppeteer"
    ]
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^25.0.8",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "prisma-erd-generator": "^2.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
